{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Web Automation",
  "version": "0.1.1",
  "identifier": "com.the-ihsan.tauri-py",
  "build": {
    "beforeDevCommand": "pnpm dev:ui",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build:daemon && pnpm build:ui",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Web Automation",
        "width": 800,
        "height": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "resources": {
      "resources/sidecar/**/*": "sidecar/"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
